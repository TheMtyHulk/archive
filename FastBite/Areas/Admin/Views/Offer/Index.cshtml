@model IEnumerable<Offer>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Offer List</h2>
<p><a href="#createOfferForm" class="btn btn-info">Create New</a></p>

<form id="createOfferForm" method="post" asp-area="Admin" asp-action="Create" class="mb-3">
    <div class="form-group">
        <label for="Name">Name</label>
        <input id="Name" name="Name" class="form-control" />
    </div>
    <div class="form-group">
        <label for="CouponType">CouponType</label>
        <select id="CouponType" name="CouponType" class="form-control">
            <option value="0">Percent</option>
            <option value="1">Rupee</option>
        </select>
    </div>
    <div class="form-group">
        <label for="Discount">Discount</label>
        <input id="Discount" name="Discount" class="form-control" />
    </div>
    <div class="form-group">
        <label for="MinimumAmount">MinimumAmount</label>
        <input id="MinimumAmount" name="MinimumAmount" class="form-control" />
    </div>
    <div class="form-group form-check">
        <input id="isActive" name="isActive" type="checkbox" class="form-check-input" value="true" />
        <label for="isActive" class="form-check-label">isActive</label>
    </div>
    <input type="hidden" name="isActive" value="false" />
    <input type="submit" value="Create" class="btn btn-primary" />
    <a asp-area="Admin" asp-action="Create" class="btn btn-secondary">Open Full Form</a>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Coupon Type</th>
            <th>Discount</th>
            <th>Minimum Amount</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr><td></td><td></td><td></td><td></td><td></td><td></td></tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.CouponType</td>
                <td>@item.Discount</td>
                <td>@item.MinimumAmount</td>
                <td>@item.isActive</td>
                <td>
                    <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-area="Admin" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
