@model IEnumerable<SubCategory>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>SubCategory List</h2>
<p><a asp-area="Admin" asp-action="Create" class="btn btn-info">Create New</a></p>

<table class="table table-bordered">
    <thead>
        <tr><td></td><td></td><td></td></tr>
        <tr>
            <th>SubCategory</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr><td></td><td></td><td></td></tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.category?.Name</td>
                <td>
                    <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-area="Admin" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
