@model IEnumerable<Restaurant>

@{
	ViewData["Title"] = "Home";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Restaurants</h2>
<div class="row">
	@foreach (var restaurant in Model)
	{
		<div class="col-md-6 mb-3">
			<div class="card">
				<div class="card-body">
					<h5 class="card-title">@restaurant.RestaurantName</h5>
					<p class="card-text">@restaurant.Address</p>
					<a class="btn btn-primary" asp-action="MenuItems" asp-route-id="@restaurant.Id">order Now</a>
				</div>
			</div>
		</div>
	}
</div>

